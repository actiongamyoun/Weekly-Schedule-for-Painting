# Supabase > Settings > Database > Connection string (URI) 복사
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT-ID].supabase.co:5432/postgres

# 관리자 로그인 비밀번호 (원하는 것으로 변경)
ADMIN_PASSWORD=admin1234

# JWT 서명 키 (랜덤 문자열, 절대 외부 노출 금지)
JWT_SECRET=change-this-to-random-string-2025

# 프론트엔드 URL (배포 후 Netlify/GitHub Pages URL 입력)
FRONTEND_URL=https://your-frontend.netlify.app

PORT=3000
